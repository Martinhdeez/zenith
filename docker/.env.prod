# Zenith AI Production Environment Variables

# ==========================================
# Database Configuration
# ==========================================
POSTGRES_USER=zenith_admin
POSTGRES_PASSWORD=zenith_secure_password_123
POSTGRES_DB=zenith_prod
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}

# ==========================================
# Backend Auth & Security
# ==========================================
# Generar un SECRET_KEY fuerte usando: openssl rand -hex 32
SECRET_KEY=e83a6b5711c2a05d8f6d3a9b24e6de4b9c1d0f5e8a7b4c9d3e2f1a0b5c8d7e6f
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=43200

# ==========================================
# Cloudinary (Almacenamiento de Archivos)
# ==========================================
# !REEMPLAZAR ESTOS VALORES CON LOS REALES!
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret
CLOUDINARY_URL=cloudinary://${CLOUDINARY_API_KEY}:${CLOUDINARY_API_SECRET}@${CLOUDINARY_CLOUD_NAME}

# ==========================================
# OpenAI API
# ==========================================
# !REEMPLAZAR CON TU CLAVE DE OPENAI!
OPENAI_API_KEY=sk-proj-tu-clave-aqui

# ==========================================
# Puertos Expuestos (Host)
# ==========================================
BACKEND_PORT=8000
FRONTEND_PORT=80
