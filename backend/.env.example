# ================================
# VARIABLES DE ENTORNO - EJEMPLO
# ================================

# Para desarrollo: cp .env.example .env.dev y edita
# Para producción: cp .env.example .env y edita
# ================================

# ==========================================
# POSTGRESQL (datos relacionales)
# ==========================================
POSTGRES_USER=zenith_user
POSTGRES_PASSWORD=zenith_password_cambiar
POSTGRES_DB=zenith_db

# ==========================================
# QDRANT (base de datos vectorial para IA)
# ==========================================
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334

# ==========================================
# BACKEND / FASTAPI
# ==========================================
# URL de conexión a PostgreSQL
DATABASE_URL=postgresql+asyncpg://zenith_user:zenith_password_cambiar@db:5432/zenith_db

# Entorno (development, staging, production)
ENVIRONMENT=development

# Modo debug (true solo en desarrollo)
DEBUG=true

# Nivel de logging (debug, info, warning, error)
LOG_LEVEL=info

# JWT Secret (cambiar en producción)
JWT_SECRET=tu_jwt_secret_super_seguro_cambiar

# ==========================================
# PUERTOS
# ==========================================
# Puerto del backend (8000 es estándar para FastAPI)
BACKEND_PORT=8000

# Puerto de PostgreSQL (5432 es estándar)
POSTGRES_PORT=5432
