# ================================
# VARIABLES DE ENTORNO - ZENITH
# ================================

# ==========================================
# POSTGRESQL (relacional + vectorial)
# ==========================================
POSTGRES_USER=zenith_user
POSTGRES_PASSWORD=zenith_password_cambiar
POSTGRES_DB=zenith_db

# ==========================================
# BACKEND / FASTAPI
# ==========================================
DATABASE_URL=postgresql+asyncpg://zenith_user:zenith_password_cambiar@db:5432/zenith_db

# JWT Secret
JWT_SECRET=tu_jwt_secret_super_seguro_cambiar

# OpenAI API Key
OPENAI_API_KEY=sk-your-openai-api-key-here

# Configuración Carpeta Almacenamiento
STORAGE_PATH=/app/storage

# Otros
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=info
BACKEND_PORT=8000
POSTGRES_PORT=5432
