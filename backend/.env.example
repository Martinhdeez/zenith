# ================================
# VARIABLES DE ENTORNO - EJEMPLO
# ================================

# Para desarrollo: cp .env.example .env.dev y edita
# Para producción: cp .env.example .env y edita
# ================================

# ==========================================
# POSTGRESQL
# ==========================================
POSTGRES_USER=usuario_postgres
POSTGRES_PASSWORD=password_super_seguro_cambiar
POSTGRES_DB=nombre_base_datos

# ==========================================
# BACKEND / FASTAPI
# ==========================================
# URL de conexión a la base de datos
DATABASE_URL=postgresql+asyncpg://usuario:password@host:puerto/database

# Entorno (development, staging, production)
ENVIRONMENT=development

# Modo debug (true solo en desarrollo)
DEBUG=false

# Nivel de logging (debug, info, warning, error)
LOG_LEVEL=info

# ==========================================
# PUERTOS
# ==========================================
# Puerto del backend (8000 es estándar para FastAPI)
BACKEND_PORT=8000

# Puerto de PostgreSQL (5432 es estándar)
POSTGRES_PORT=5432

